SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
GITHUB_TOKEN=ghp_your-github-token
GROQ_API_KEY=gsk_your-groq-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
HUGGINGFACE_API_TOKEN=hf_your-huggingface-token

# GitHub OAuth app (Phase 6 — Settings > Developer settings > OAuth Apps)
# Authorization callback URL on the GitHub side must point at the BACKEND:
#   http://127.0.0.1:8000/auth/callback
GITHUB_CLIENT_ID=Iv1.your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
FRONTEND_URL=http://localhost:3000

# Agent model overrides (optional — defaults match skill file LLM strategy)
# REPO_ANALYZER_MODEL=llama-3.3-70b-versatile
# EXPLANATION_AGENT_MODEL=claude-sonnet-4-20250514
# QUESTION_GENERATOR_MODEL=claude-sonnet-4-20250514
# GAP_DETECTOR_MODEL=llama-3.3-70b-versatile
